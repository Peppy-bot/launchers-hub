// OpenArm v2.0 bimanual Isaac Sim teleop with self-collision avoidance. The backbone
// is the coordinator: it consumes the commander's joint stream + the sim's
// arm_states + the collision toggle, runs the self-collision governor over both
// arms, and streams governed setpoints the sim arms relabel onto the engine. The
// sim arms are thin followers (arm_governed_setpoints -> arm_sim_passthrough).
// Launch: peppy stack launch ./openarm_v2_teleop_isaac.json5
{
  peppy_schema: "launcher/v1",
  deployments: [
    {
      source: {
        name: "openarm_robot_initializer_isaac",
        tag: "v1"
      },
      instances: [
        {
          instance_id: "sim_inst",
          // Rate (Hz) of the sim's measured-state streams (arm_states /
          // gripper_states). The backbone consumes arm_states for the governor.
          arguments: {
            hardware_version: "v2",
            state_rate_hz: 100
          },
          bindings: {
            // One contract slot per relabeling follower: the sim consumes each
            // side's passthrough setpoints from exactly that follower.
            left_arm_cmd: "left_arm_inst",
            right_arm_cmd: "right_arm_inst",
            left_gripper_cmd: "left_grip_inst",
            right_gripper_cmd: "right_grip_inst"
          },
        }
      ]
    },
    {
      source: {
        name: "openarm_arm_isaac",
        tag: "v1"
      },
      instances: [
        // Thin followers: each relabels the backbone's arm_governed_setpoints for its
        // arm_id onto arm_sim_passthrough. No motion params (the backbone owns those).
        {
          instance_id: "left_arm_inst",
          arguments: {
            arm_id: 0
          },
          bindings: {
            // Measured joint state from the sim engine.
            engine_states: "sim_inst"
          },
        },
        {
          instance_id: "right_arm_inst",
          arguments: {
            arm_id: 1
          },
          bindings: {
            // Measured joint state from the sim engine.
            engine_states: "sim_inst"
          },
        }
      ]
    },
    {
      source: {
        name: "openarm_gripper_isaac",
        tag: "v1"
      },
      instances: [
        {
          instance_id: "left_grip_inst",
          arguments: {
            gripper_id: 0,
            control_rate_hz: 100,
          },
          bindings: {
            // Measured opening from the sim engine.
            engine_states: "sim_inst"
          },
        },
        {
          instance_id: "right_grip_inst",
          arguments: {
            gripper_id: 1,
            control_rate_hz: 100,
          },
          bindings: {
            // Measured opening from the sim engine.
            engine_states: "sim_inst"
          },
        }
      ]
    },
    {
      source: {
        name: "openarm_backbone",
        tag: "v1"
      },
      instances: [
        {
          instance_id: "backbone_inst",
          // The backbone coordination rate and commander-stream watchdog. URDF and meshes
          // come from the v2 description; left_base/right_base name the v2 mounts below. The governor's launch
          // band, enable, and startup EE-speed cap are required arguments (no node
          // defaults) until the commander's live governor_control stream takes over;
          // the sim cap is permissive. The commander streams and the live
          // governor controls are bound to the panel below; the arms and
          // grippers are paired below.
          arguments: {
            hardware_version: "v2",
            left_base: "openarm_left_base_link",
            right_base: "openarm_right_base_link",
            control_rate_hz: 100,
            d_stop: 0.005,
            d_safe: 0.02,
            collision_governor_enabled: true,
            max_ee_velocity_m_s: 0.5
          },
          bindings: {
            robot_init: "sim_inst",
            // The commander's setpoint streams and its governor toggle. A slot
            // receives ONLY from the one producer bound here (no wildcard
            // fallback); removing a line is a launch validation error, since
            // every declared slot must be bound.
            commander: "commander_inst",
            collision_ctrl: "commander_inst"
          },
          // Pair each arm and each gripper with the backbone: the backbone plays the
          // commander role of arm_link / gripper_link, streams the GOVERNED
          // setpoint down each pair (no id demux), and reads that follower's
          // measured state back on the same pair. Both commander streams
          // (arm_joint_commands, gripper_commands) run through the governor
          // before anything reaches a follower.
          pairings: {
            left_arm_link: "left_arm_inst",
            right_arm_link: "right_arm_inst",
            left_gripper_link: "left_grip_inst",
            right_gripper_link: "right_grip_inst"
          },
        }
      ]
    },
    {
      source: {
        name: "openarm_commander",
        tag: "v1"
      },
      instances: [
        {
          instance_id: "commander_inst",
          // Sim runs faster than the real arm: the commander's EE-speed cap (streamed
          // to the backbone) is above the conservative real value, but bounded so the
          // d_safe..d_stop band still spans a couple of control cycles of reaction.
          // The band cannot widen past the ~24 mm rest-pose clearance, so the cap is
          // what sets that margin. Band + launch enable kept in step with backbone.
          arguments: {
            command_rate_hz: 100,
            hardware_version: "v2",
            collision_governor_enabled: true,
            d_stop: 0.005,
            d_safe: 0.02,
            max_ee_velocity_m_s: 0.5
          },
          bindings: {
            // The backbone: move actions + the collision_status proximity feed.
            backbone: "backbone_inst",
            // Live readouts: each side's state slot binds that side's arm or
            // gripper instance, so the slot itself names the side.
            left_arm_states: "left_arm_inst",
            right_arm_states: "right_arm_inst",
            left_gripper_states: "left_grip_inst",
            right_gripper_states: "right_grip_inst",
          },
        }
      ]
    }
  ]
}