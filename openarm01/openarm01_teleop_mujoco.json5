// openarm01 bimanual MuJoCo teleop with self-collision avoidance. The backbone
// is the coordination hub: it consumes the commander's joint stream + the sim's
// arm_states + the collision toggle, runs the self-collision governor over both
// arms, and streams governed setpoints the sim arms relabel onto the engine. The
// sim arms are thin followers (arm_governed_setpoints -> arm_sim_passthrough).
// Launch: peppy stack launch ./openarm01_teleop_mujoco.json5
{
  peppy_schema: "launcher/v1",
  deployments: [
    {
      source: { name: "openarm01_robot_initializer_mujoco", tag: "v1" },
      instances: [
        {
          instance_id: "sim",
          // Rate (Hz) of the sim's measured-state streams (arm_states /
          // gripper_states). The hub consumes arm_states for the governor.
          arguments: { state_rate_hz: 100 },
        }
      ]
    },
    {
      source: { name: "openarm01_arm_mujoco", tag: "v1" },
      instances: [
        // Thin followers: each relabels the hub's arm_governed_setpoints for its
        // arm_id onto arm_sim_passthrough. No motion params (the hub owns those).
        { instance_id: "left_arm_inst", arguments: { arm_id: 0 } },
        { instance_id: "right_arm_inst", arguments: { arm_id: 1 } }
      ]
    },
    {
      source: { name: "openarm01_gripper_mujoco", tag: "v1" },
      instances: [
        {
          instance_id: "left_grip_inst",
          arguments: { gripper_id: 0, control_rate_hz: 100, stream_timeout_s: 0.5 },
        },
        {
          instance_id: "right_grip_inst",
          arguments: { gripper_id: 1, control_rate_hz: 100, stream_timeout_s: 0.5 },
        }
      ]
    },
    {
      source: { name: "openarm01_backbone", tag: "v1" },
      instances: [
        {
          instance_id: "backbone_inst",
          // The hub coordination rate and operator-stream watchdog. URDF, meshes, and
          // base links take their vendored container defaults. The governor's launch
          // band, enable, and startup EE-speed cap are required arguments (no node
          // defaults) until the operator's live governor_control stream takes over;
          // the sim cap is permissive. arm_joint_commands, arm_states, and the live
          // governor controls resolve via from_any, so they need no bindings.
          arguments: {
            control_rate_hz: 100,
            stream_timeout_s: 0.5,
            d_stop: 0.005,
            d_safe: 0.02,
            collision_governor_enabled: true,
            max_ee_velocity_m_s: 1.0
          },
          bindings: {
            robot_init:    "sim",
            left_gripper:  "left_grip_inst",
            right_gripper: "right_grip_inst"
          },
        }
      ]
    },
    {
      source: { name: "openarm01_joint_commander", tag: "v1" },
      instances: [
        {
          instance_id: "commander",
          // Sim runs fast: raise the operator EE-speed cap (streamed to the hub)
          // above the conservative real-arm value. Band + launch enable kept in step
          // with backbone_inst.
          arguments: {
            command_rate_hz: 100,
            collision_governor_enabled: true,
            d_stop: 0.005,
            d_safe: 0.02,
            max_ee_velocity_m_s: 1.0
          },
          bindings: { backbone: "backbone_inst" },
        }
      ]
    }
  ]
}
