// openarm01 bimanual MuJoCo teleop. MVP scope: joint-space passthrough; IK +
// CD + cameras land post-MVP. Launch: peppy stack launch ./openarm01_teleop_mujoco.json5
{
  peppy_schema: "launcher_v1",
  deployments: [
    {
      source: { name: "openarm01_robot_initializer_mujoco", tag: "v1" },
      instances: [
        { instance_id: "sim" }
      ]
    },
    {
      source: { name: "openarm01_arm_mujoco", tag: "v1" },
      instances: [
        {
          instance_id: "left_arm_inst",
          arguments: { arm_id: 0, control_rate_hz: 100, stream_timeout_s: 0.5 },
          bindings: { sim: "sim" },
        },
        {
          instance_id: "right_arm_inst",
          arguments: { arm_id: 1, control_rate_hz: 100, stream_timeout_s: 0.5 },
          bindings: { sim: "sim" },
        }
      ]
    },
    {
      source: { name: "openarm01_gripper_mujoco", tag: "v1" },
      instances: [
        {
          instance_id: "left_grip_inst",
          arguments: { gripper_id: 0, control_rate_hz: 100, stream_timeout_s: 0.5 },
          bindings: { sim: "sim" },
        },
        {
          instance_id: "right_grip_inst",
          arguments: { gripper_id: 1, control_rate_hz: 100, stream_timeout_s: 0.5 },
          bindings: { sim: "sim" },
        }
      ]
    },
    {
      source: { name: "openarm01_backbone", tag: "v1" },
      instances: [
        {
          instance_id: "backbone_inst",
          bindings: {
            robot_init:    "sim",
            left_arm:      "left_arm_inst",
            right_arm:     "right_arm_inst",
            left_gripper:  "left_grip_inst",
            right_gripper: "right_grip_inst"
          },
        }
      ]
    },
    {
      source: { name: "openarm01_joint_commander", tag: "v1" },
      instances: [
        {
          instance_id: "commander",
          bindings: { backbone: "backbone_inst" },
        }
      ]
    }
  ]
}
