// openarm01 bimanual teleop on MuJoCo — v0.10 deployment shape.
//
// Brings up the full MVP stack:
//   robot_initializer_mujoco (×1)     — owns the MuJoCo process + bridge_extension
//   openarm01_arm_mujoco     (×2)     — left + right arm, Rust runtime per side
//   openarm01_gripper_mujoco (×2)     — left + right gripper, Rust runtime per side
//   openarm01_backbone       (×1)     — joint-space orchestrator, pinned link_ids
//   openarm01_joint_commander(×1)     — axum HTTP+WS browser UI on :8765 (PEPPY_JC_PORT, PEPPY_JC_BIND_IP)
//
// MVP scope: no IK / collisions_detection / cameras. Add when those nodes
// migrate to v0.10 (Module 4 — Safety Pipeline).
//
// Launch:  peppy stack launch ./openarm01_teleop_mujoco.json5
{
  peppy_schema: "launcher_v1",
  deployments: [
    {
      source: { name: "openarm01_robot_initializer_mujoco", tag: "v1" },
      instances: [
        { instance_id: "sim" }
      ]
    },
    {
      source: { name: "openarm01_arm_mujoco", tag: "v1" },
      instances: [
        {
          instance_id: "left_arm_inst",
          arguments: { arm_id: 0 },
          bindings: { sim: "sim" },
        },
        {
          instance_id: "right_arm_inst",
          arguments: { arm_id: 1 },
          bindings: { sim: "sim" },
        }
      ]
    },
    {
      source: { name: "openarm01_gripper_mujoco", tag: "v1" },
      instances: [
        {
          instance_id: "left_grip_inst",
          arguments: { gripper_id: 0 },
          bindings: { sim: "sim" },
        },
        {
          instance_id: "right_grip_inst",
          arguments: { gripper_id: 1 },
          bindings: { sim: "sim" },
        }
      ]
    },
    {
      source: { name: "openarm01_backbone", tag: "v1" },
      instances: [
        {
          instance_id: "backbone_inst",
          bindings: {
            robot_init:    "sim",
            left_arm:      "left_arm_inst",
            right_arm:     "right_arm_inst",
            left_gripper:  "left_grip_inst",
            right_gripper: "right_grip_inst"
          },
        }
      ]
    },
    {
      source: { name: "openarm01_joint_commander", tag: "v1" },
      instances: [
        {
          instance_id: "commander",
          bindings: { backbone: "backbone_inst" },
        }
      ]
    }
  ]
}
