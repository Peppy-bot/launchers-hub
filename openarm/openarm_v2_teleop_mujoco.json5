// OpenArm v2.0 bimanual MuJoCo teleop with self-collision avoidance. The backbone
// is the coordinator: it consumes the commander's per-limb pairing streams +
// the collision toggle, runs the self-collision governor over both
// arms, and streams governed setpoints straight to the engine, which plays the
// follower role of every limb's pairing itself.
// Launch: peppy stack launch ./openarm_v2_teleop_mujoco.json5
{
  peppy_schema: "launcher/v1",
  deployments: [
    {
      source: {
        name: "openarm_robot_initializer_mujoco",
        tag: "v1"
      },
      instances: [
        {
          instance_id: "sim_inst",
          // Rate (Hz) of the engine's measured-state streams on its pairing
          // slots, which the backbone and any observer consume.
          arguments: {
            hardware_version: "v2",
            state_rate_hz: 100
          },
        }
      ]
    },
    {
      source: {
        name: "openarm_backbone",
        tag: "v1"
      },
      instances: [
        {
          instance_id: "backbone_inst",
          // The backbone coordination rate and commander-stream watchdog. URDF, meshes,
          // and the per-side chain base links all come from the v2 description. The
          // governor's launch band, enable, and startup EE-speed cap are required
          // arguments (no node defaults) until the commander's live governor_control
          // stream takes over; the sim cap is permissive. The commander streams, the
          // live governor controls, the arms, and the grippers are all linked below.
          arguments: {
            hardware_version: "v2",
            control_rate_hz: 100,
            d_stop: 0.005,
            d_safe: 0.02,
            collision_governor_enabled: true,
            max_ee_velocity_m_s: 0.5
          },
          links: {
            robot_init: "sim_inst",
            // The operator's governor toggle. A slot receives ONLY from the
            // one producer linked here (no wildcard fallback); removing a line
            // is a launch validation error, since every declared required slot
            // must be linked.
            collision_ctrl: "commander_inst",
            // Link each arm and each gripper with the backbone: the backbone plays the
            // leader role of joint_link / gripper_link, streams the GOVERNED
            // setpoint down each pair (no id demux), and reads that follower's
            // measured state back on the same pair. Both upstream command
            // streams run through the governor before anything reaches a
            // follower.
            left_arm_link: "sim_inst/left_arm",
            right_arm_link: "sim_inst/right_arm",
            left_gripper_link: "sim_inst/left_gripper",
            right_gripper_link: "sim_inst/right_gripper"
          },
        }
      ]
    },
    {
      source: {
        name: "openarm_commander",
        tag: "v1"
      },
      instances: [
        {
          instance_id: "commander_inst",
          // Sim runs faster than the real arm: the commander's EE-speed cap (streamed
          // to the backbone) is above the conservative real value, but bounded so the
          // d_safe..d_stop band still spans a couple of control cycles of reaction.
          // The band cannot widen past the ~24 mm rest-pose clearance, so the cap is
          // what sets that margin. Band + launch enable kept in step with backbone.
          arguments: {
            command_rate_hz: 100,
            hardware_version: "v2",
            collision_governor_enabled: true,
            d_stop: 0.005,
            d_safe: 0.02,
            max_ee_velocity_m_s: 0.5
          },
          links: {
            // The backbone: move actions + the collision_status proximity feed.
            backbone: "backbone_inst",
            // The command loop: this panel plays the leader role of each limb's
            // pairing; each slot plugs into the backbone's matching leader
            // socket (target/socket form: the backbone holds one per limb).
            left_arm: "backbone_inst/leader_left_arm",
            right_arm: "backbone_inst/leader_right_arm",
            left_gripper: "backbone_inst/leader_left_gripper",
            right_gripper: "backbone_inst/leader_right_gripper",
            // Live readouts: an observer link names the FOLLOWER side of the
            // pairing it watches; in sim that is the engine, one slot per limb.
            observed_left_arm: "sim_inst/left_arm",
            observed_right_arm: "sim_inst/right_arm",
            observed_left_gripper: "sim_inst/left_gripper",
            observed_right_gripper: "sim_inst/right_gripper",
          },
        }
      ]
    }
  ]
}