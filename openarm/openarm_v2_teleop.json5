// OpenArm v2.0 bimanual real-hardware teleop with self-collision avoidance. Same node
// graph as openarm_v1_teleop, but hardware_version is "v2": the arms build the v2 model
// (reoriented frames, v2 base links) and the gripper slot is openarm_gripper_v2 (revolute
// pinch gripper, POS_FORCE with force feedback). Launch: peppy stack launch ./openarm_v2_teleop.json5
//
// CAN topology: left arm + left gripper share can0, right arm + right gripper share can1.
{
  peppy_schema: "launcher/v1",
  deployments: [
    {
      source: { name: "openarm_arm", tag: "v1" },
      instances: [
        {
          instance_id: "left_arm_inst",
          arguments: {
            arm_id: 0,
            hardware_version: "v2",
            can_interface: "can0",
            base_link: "openarm_left_base_link",
            control_rate_hz: 100,
            state_rate_hz: 100
          },
        },
        {
          instance_id: "right_arm_inst",
          arguments: {
            arm_id: 1,
            hardware_version: "v2",
            can_interface: "can1",
            base_link: "openarm_right_base_link",
            control_rate_hz: 100,
            state_rate_hz: 100
          },
        }
      ]
    },
    {
      source: { name: "openarm_gripper_v2", tag: "v1" },
      instances: [
        {
          instance_id: "left_grip_inst",
          arguments: {
            gripper_id: 0,
            can_interface: "can0",
            control_rate_hz: 100,
            state_rate_hz: 100,
            stream_timeout_s: 0.5
          },
        },
        {
          instance_id: "right_grip_inst",
          arguments: {
            gripper_id: 1,
            can_interface: "can1",
            control_rate_hz: 100,
            state_rate_hz: 100,
            stream_timeout_s: 0.5
          },
        }
      ]
    },
    {
      // Declared after the arms/grippers it aggregates: the real initializer polls
      // each component's is_ready and reports the robot ready only when all are up.
      source: { name: "openarm_robot_initializer", tag: "v1" },
      instances: [
        {
          instance_id: "robot_init",
          bindings: {
            left_arm:      "left_arm_inst",
            right_arm:     "right_arm_inst",
            left_gripper:  "left_grip_inst",
            right_gripper: "right_grip_inst"
          },
        }
      ]
    },
    {
      source: { name: "openarm_backbone", tag: "v1" },
      instances: [
        {
          instance_id: "backbone_inst",
          // Unified 100 Hz stack; hardware_version selects the v2 collision model. The
          // governor band, launch enable, and startup EE-speed cap are required (no node
          // defaults); the cap is conservative for the real arm until the operator's live
          // cap takes over.
          arguments: {
            hardware_version: "v2",
            control_rate_hz: 100,
            stream_timeout_s: 0.5,
            d_stop: 0.005,
            d_safe: 0.02,
            collision_governor_enabled: true,
            max_ee_velocity_m_s: 0.25
          },
          bindings: {
            robot_init:    "robot_init",
            left_gripper:  "left_grip_inst",
            right_gripper: "right_grip_inst"
          },
        }
      ]
    },
    {
      source: { name: "openarm_joint_commander", tag: "v1" },
      instances: [
        {
          instance_id: "commander",
          arguments: {
            command_rate_hz: 100,
            collision_governor_enabled: true,
            d_stop: 0.005,
            d_safe: 0.02,
            max_ee_velocity_m_s: 0.25
          },
          bindings: { backbone: "backbone_inst" },
        }
      ]
    }
  ]
}
