// OpenArm v2.0 bimanual real-hardware teleop with self-collision avoidance. Same node
// graph as openarm_v1_teleop, but hardware_version is "v2": the arms build the v2 model
// (reoriented frames, v2 base links) and the gripper slot is openarm_gripper_v2 (revolute
// pinch gripper, POS_FORCE with force feedback). Launch: peppy stack launch ./openarm_v2_teleop.json5
//
// CAN topology: left arm + left gripper share the left_arm channel, right arm + right gripper share right_arm.
{
  peppy_schema: "launcher/v1",
  deployments: [
    {
      source: {
        name: "openarm_arm",
        tag: "v1"
      },
      instances: [
        {
          instance_id: "left_arm_inst",
          arguments: {
            arm_id: 0,
            hardware_version: "v2",
            can_interface: "left_arm",
            control_rate_hz: 100,
            state_rate_hz: 100
          },
        },
        {
          instance_id: "right_arm_inst",
          arguments: {
            arm_id: 1,
            hardware_version: "v2",
            can_interface: "right_arm",
            control_rate_hz: 100,
            state_rate_hz: 100
          },
        }
      ]
    },
    {
      source: {
        name: "openarm_gripper_v2",
        tag: "v1"
      },
      instances: [
        {
          instance_id: "left_grip_inst",
          arguments: {
            gripper_id: 0,
            can_interface: "left_arm",
            control_rate_hz: 100,
            state_rate_hz: 100,
          },
        },
        {
          instance_id: "right_grip_inst",
          arguments: {
            gripper_id: 1,
            can_interface: "right_arm",
            control_rate_hz: 100,
            state_rate_hz: 100,
          },
        }
      ]
    },
    {
      // Declared after the arms/grippers it aggregates: the real initializer polls
      // each component's is_ready and reports the robot ready only when all are up.
      source: {
        name: "openarm_robot_initializer",
        tag: "v1"
      },
      instances: [
        {
          instance_id: "robot_init_inst",
          bindings: {
            left_arm: "left_arm_inst",
            right_arm: "right_arm_inst",
            left_gripper: "left_grip_inst",
            right_gripper: "right_grip_inst"
          },
        }
      ]
    },
    {
      source: {
        name: "openarm_backbone",
        tag: "v1"
      },
      instances: [
        {
          instance_id: "backbone_inst",
          // Unified 100 Hz stack; hardware_version selects the v2 collision model. The
          // governor band, launch enable, and startup EE-speed cap are required (no node
          // defaults); the cap is conservative for the real arm until the commander's live
          // cap takes over.
          arguments: {
            hardware_version: "v2",
            control_rate_hz: 100,
            d_stop: 0.005,
            d_safe: 0.02,
            collision_governor_enabled: true,
            max_ee_velocity_m_s: 0.25
          },
          bindings: {
            robot_init: "robot_init_inst",
            // The commander's setpoint streams and its governor toggle. A slot
            // receives ONLY from the one producer bound here (no wildcard
            // fallback); removing a line is a launch validation error, since
            // every declared slot must be bound.
            commander: "commander_inst",
            collision_ctrl: "commander_inst"
          },
          // Pair each arm and each gripper with the backbone: the backbone plays the
          // commander role of arm_link / gripper_link, streams the GOVERNED
          // setpoint down each pair (no id demux), and reads that follower's
          // measured state back on the same pair. Both commander streams
          // (arm_joint_commands, gripper_commands) run through the governor
          // before anything reaches a follower.
          pairings: {
            left_arm_link: "left_arm_inst",
            right_arm_link: "right_arm_inst",
            left_gripper_link: "left_grip_inst",
            right_gripper_link: "right_grip_inst"
          },
        }
      ]
    },
    {
      source: {
        name: "openarm_commander",
        tag: "v1"
      },
      instances: [
        {
          instance_id: "commander_inst",
          arguments: {
            command_rate_hz: 100,
            hardware_version: "v2",
            collision_governor_enabled: true,
            d_stop: 0.005,
            d_safe: 0.02,
            max_ee_velocity_m_s: 0.25
          },
          bindings: {
            // The backbone: move actions + the collision_status proximity feed.
            backbone: "backbone_inst",
            // Live readouts: each side has its own one-producer contract slot,
            // plus the backbone's proximity stream.
            left_arm_states: "left_arm_inst",
            right_arm_states: "right_arm_inst",
            left_gripper_states: "left_grip_inst",
            right_gripper_states: "right_grip_inst",
          },
        }
      ]
    }
  ]
}